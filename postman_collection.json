{
  "info": {
    "name": "Fuel Route Optimizer API",
    "description": "Demo collection for optimizing fuel routes across the USA with cost-effective fuel stops",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Demo Requests",
      "description": "Ready-to-use requests for showcasing the API",
      "item": [
        {
          "name": "Dallas → Phoenix (Long Route)",
          "description": "Cross-country route with multiple fuel stops expected (~1000 miles)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"start\": \"Dallas, TX\", \"destination\": \"Phoenix, AZ\"}"
            },
            "url": {
              "raw": "http://127.0.0.1:8000/api/v1/optimize-route/",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["api", "v1", "optimize-route", ""]
            }
          }
        },
        {
